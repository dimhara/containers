ARG TARGET_DEVICE=cuda12.4
FROM ghcr.io/dimhara/containers/hf-base:${TARGET_DEVICE}

USER root
COPY vibevoice_runpod/ /app/
RUN chown -R agent:agent /app

USER agent
WORKDIR /app
RUN uv pip install --no-cache "transformers>=5.4.0" "huggingface_hub>=0.32.0" cryptography runpod && \
    chmod +x /app/src/start.sh

CMD ["bash", "/app/src/start.sh"]