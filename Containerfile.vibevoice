ARG TARGET_DEVICE=cuda12.4
FROM ghcr.io/dimhara/containers/hf-base:${TARGET_DEVICE}

USER root
ENV HF_HOME=/runpod-volume/huggingface-cache
RUN pip install --no-cache-dir "transformers>=5.3.0" cryptography

COPY vibevoice_runpod/ /app/
WORKDIR /app

RUN chmod +x /app/src/start.sh

CMD ["bash", "/app/src/start.sh"]